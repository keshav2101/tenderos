# ============================================================
# TenderOS v1.0.0 — Production Environment Variables Template
# Copy to .env and fill in ALL values before deploying
# NEVER commit .env to version control
# ============================================================

# ─── Runtime ────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO

# ─── JWT (generate with: openssl rand -hex 64) ─────────────
JWT_SECRET=CHANGE_ME_USE_openssl_rand_-hex_64
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

# ─── PostgreSQL ─────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tenderos
POSTGRES_USER=tenderos
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ─── Redis ──────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# ─── RabbitMQ ───────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=tenderos
RABBITMQ_PASSWORD=CHANGE_ME_STRONG_RABBIT_PASSWORD
RABBITMQ_VHOST=tenderos

# ─── MinIO (Object Storage) ─────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=tenderos_minio_prod
MINIO_SECRET_KEY=CHANGE_ME_STRONG_MINIO_SECRET
MINIO_BUCKET_DOCUMENTS=tender-documents
MINIO_BUCKET_PROFILES=company-profiles
MINIO_SECURE=false

# ─── Qdrant (Vector DB) ─────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=CHANGE_ME_QDRANT_API_KEY

# ─── Neo4j (Knowledge Graph) ────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_NEO4J_PASSWORD

# ─── OpenSearch ─────────────────────────────────────────────
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200

# ─── AI / LLM ───────────────────────────────────────────────
LLM_PROVIDER=gemini
GEMINI_API_KEY=YOUR_GOOGLE_GEMINI_API_KEY
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OLLAMA_HOST=

# ─── Stripe (Billing) ───────────────────────────────────────
STRIPE_API_KEY=sk_live_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
STRIPE_PRICE_SME=price_YOUR_SME_PRICE_ID
STRIPE_PRICE_ENTERPRISE=price_YOUR_ENTERPRISE_PRICE_ID

# ─── Email (SMTP) ───────────────────────────────────────────
SMTP_HOST=smtp.yourdomain.in
SMTP_PORT=587
SMTP_USER=noreply@tenderos.in
SMTP_PASSWORD=YOUR_SMTP_PASSWORD
FROM_EMAIL=noreply@tenderos.in

# ─── Google OAuth (optional) ────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.tenderos.in/auth/google/callback

# ─── Microsoft Azure AD OAuth (optional) ────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ─── External GeM / CPPP API ────────────────────────────────
GEM_API_KEY=
GEM_API_BASE=https://gem.gov.in/api
CPPP_BASE_URL=https://eprocure.gov.in

# ─── Frontend URLs ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.tenderos.in
NEXT_PUBLIC_APP_URL=https://tenderos.in
CORS_ORIGINS=https://tenderos.in,https://app.tenderos.in

# ─── Twilio (SMS/WhatsApp) ──────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+91XXXXXXXXXX
